      <aliases enabled='yes' />
      <column caption='Goals-Pens' datatype='integer' hidden='true' name='[Calculation_1105582551056388]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[goals] - [goals_pens]' />
      </column>
      <column caption='ShotsOT' datatype='integer' hidden='true' name='[Calculation_1105582551240709]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[shots_on_target] - [shots]' />
      </column>
      <column caption='Tackles+Interception' datatype='integer' name='[Calculation_1105582565613574]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[tackles_won]+[interceptions]' />
      </column>
      <column caption='FW Rating' datatype='real' name='[Calculation_1612182795481092]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.40 * [goals_per90]&#13;&#10;+&#13;&#10;0.30 * [assists_per90]&#13;&#10;+&#13;&#10;0.20 * [shots_on_target_pct]&#13;&#10;+&#13;&#10;0.10 * [plus_minus]' />
      </column>
      <column caption='Goals Score' datatype='real' name='[Calculation_1612182797971461]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[goals_per90] * 40' />
      </column>
      <column caption='Assists Score' datatype='real' name='[Calculation_1612182798061574]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[assists_per90] * 30' />
      </column>
      <column caption='Accuracy Score' datatype='real' name='[Calculation_1612182798147591]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([shots_on_target_pct] / 100) * 20' />
      </column>
      <column caption='TeamEffect Score' datatype='real' name='[Calculation_1612182798221320]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[plus_minus_per90] * 10' />
      </column>
      <column caption='FW Score' datatype='real' name='[Calculation_1612182798319625]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1612182797971461]&#13;&#10;+&#13;&#10;[Calculation_1612182798061574]&#13;&#10;+&#13;&#10;[Calculation_1612182798147591]&#13;&#10;+&#13;&#10;[Calculation_1612182798221320]' />
      </column>
      <column caption='PositionSplit' datatype='string' name='[Calculation_1769962086752257]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([position], &quot;,&quot;) THEN&#13;&#10;    SPLIT([position], &quot;,&quot;, 1)&#13;&#10;ELSE&#13;&#10;    [position]&#13;&#10;END' />
      </column>
